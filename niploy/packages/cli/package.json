{
  "name": "@niploy/cli",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "tsx -C '@niploy/tsx' src/bin.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "niploy": "dist/bin.js"
  },
  "files": [
    "dist",
    "src",
    "!**/*.tsbuildinfo"
  ],
  "imports": {
    "#niploy/*.js": {
      "@niploy/source": "./src/*.ts",
      "@niploy/tsx": "./src/*.js",
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@niploy/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@effect/cli": "catalog:",
    "@effect/platform": "catalog:",
    "@effect/platform-node": "catalog:",
    "effect": "catalog:",
    "ink": "catalog:",
    "react": "catalog:",
    "signal-exit": "catalog:",
    "tslib": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/signal-exit": "catalog:",
    "tsx": "catalog:"
  }
}
