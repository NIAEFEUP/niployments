{
  "compilerOptions": {
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "experimentalDecorators": true,
    "outDir": "bin",
    "target": "ESNext",
    "sourceMap": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "pretty": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": ".",
    "customConditions": ["@niaefeup/niployments"]
  },
  "include": [
    "assets/**/*.ts",
    "resources/**/*.ts",
    "services/**/*.ts",
    "utils/**/*.ts",
    "index.ts"
  ],
  "exclude": ["node_modules", "bin", "crds"]
}
