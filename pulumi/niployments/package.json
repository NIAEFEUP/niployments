{
    "name": "@niaefeup/niployments-pulumi",
    "main": "bin/index.js",
    "type": "module",
    "private": true,
    "scripts": {
        "lint": "eslint --max-warnings=0 .",
        "lint:fix": "eslint --fix .",
        "prettier": "prettier --check .",
        "prettier:fix": "prettier --write .",
        "build": "tsc",
        "build:watch": "tsc --watch",
        "check": "pnpm run lint && pnpm run prettier"
    },
    "devDependencies": {
        "@eslint/js": "^9.7.0",
        "@types/eslint__js": "^8.42.3",
        "@types/node": "^18.19.39",
        "eslint": "^9.7.0",
        "eslint-plugin-only-warn": "^1.1.0",
        "prettier": "3.3.3",
        "typescript": "^5.5.3",
        "typescript-eslint": "8.0.0-alpha.44"
    },
    "dependencies": {
        "@pulumi/crds": "workspace:^",
        "@pulumi/kubernetes": "^4.24.1",
        "@pulumi/pulumi": "^3.209.0"
    },
    "imports": {
        "#resources/*": {
            "default": "./bin/resources/*",
            "import": "./bin/resources/*",
            "@niaefeup/niployments": "./resources/*"
        },
        "#services/*": {
            "default": "./bin/services/*",
            "import": "./bin/services/*",
            "@niaefeup/niployments": "./services/*"
        },
        "#utils/*": {
            "default": "./bin/utils/*",
            "import": "./bin/utils/*",
            "@niaefeup/niployments": "./utils/*"
        }
    }
}
